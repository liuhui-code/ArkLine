{
  "name": "arkline",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "vite",
    "cli": "node scripts/arkline-cli.mjs",
    "build:semantic-worker": "pnpm --dir semantic-worker build",
    "build:semantic-sidecar": "pnpm build:semantic-worker && node scripts/build-semantic-sidecar.mjs",
    "build:indexer-sidecar": "node scripts/build-indexer-sidecar.mjs",
    "test:semantic-worker": "pnpm --dir semantic-worker test",
    "test:frontend": "vitest run",
    "test:frontend:quality": "vitest run tests/frontend/package-scripts.test.ts tests/frontend/quality-gate-manifest.test.ts tests/frontend/indexing-roadmap-status.test.ts tests/frontend/ci-workflow-gates.test.ts tests/frontend/packaged-soak-foundation.test.ts tests/frontend/packaged-soak-webdriver.test.ts tests/frontend/readme-quality-gates.test.ts tests/frontend/check-line-count.test.mjs tests/frontend/app-crash-boundary.test.tsx tests/frontend/editor-crash-boundary.test.tsx tests/frontend/ui-latency-monitor.test.ts",
    "test:rust": "node scripts/test-rust.mjs",
    "smoke:semantic": "node scripts/smoke-semantic.mjs --fixture",
    "perf:runtime": "node scripts/perf-runtime-gate.mjs --strict",
    "fixture:performance": "node scripts/generate-performance-fixture.mjs",
    "perf:packaged:windows": "node scripts/run-windows-packaged-soak.mjs --strict",
    "check:whitespace": "git diff --check HEAD --",
    "check:line-count": "node scripts/check-line-count.mjs --limit=500",
    "check:fast": "pnpm check:whitespace && pnpm check:line-count && pnpm test:semantic-worker && pnpm test:frontend:quality && pnpm test:rust && pnpm build && pnpm perf:runtime",
    "check": "pnpm check:whitespace && pnpm check:line-count && pnpm test && pnpm test:rust && pnpm build && pnpm perf:runtime",
    "build": "pnpm build:semantic-worker && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "check:windows-build": "powershell -ExecutionPolicy Bypass -File scripts/check-windows-build.ps1",
    "package:windows": "node scripts/package-windows.mjs --target=windows-installer",
    "package:windows:installer": "node scripts/package-windows.mjs --target=windows-installer",
    "package:windows:portable": "node scripts/package-windows.mjs --target=windows-portable",
    "package:mac": "node scripts/package-windows.mjs --target=mac",
    "preview": "vite preview",
    "test": "pnpm test:semantic-worker && pnpm test:frontend",
    "test:watch": "vitest",
    "tauri": "node scripts/tauri-cli.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "@yao-pkg/pkg": "6.21.0",
    "esbuild": "0.21.5",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "5.4.21",
    "vitest": "^3.2.4"
  }
}
